# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.dev.vars
.dev.vars.*
# The scaffolder template file `.dev.vars.example.tmpl` (under
# `packages/create-nextion-app/src/templates/`) must be committed so
# downstream users can render their own `.dev.vars.example` at scaffold
# time. The matching rendered file in *their* project is whitelisted by
# the per-project `.gitignore` the scaffolder writes.
!.dev.vars.example.tmpl

# wrangler local state & secrets
.wrangler/
.vinext/
.agent-browser-home/
.dbg/
tmp-lh-*.json
.tmp-lighthouse-*.json
debug-turnstile-*.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
/dist/

# monorepo
.pnpm-store
node_modules/
**/node_modules/
dist/
**/dist/
.turbo/
*.tsbuildinfo
**/.next/
**/out/
**/.wrangler/
.playwright-cli/

# Consumer apps scaffolded via `npm create nextion-app` are kept locally
# as working references and never pushed; downstream users scaffold
# their own apps from the published packages.
apps/

# IDE / agent working state
.agent-runs/
.trae/
.worktrees/
packages/nextion-skill/.trae/

# CI-only npm auth file written by .github/workflows/release.yml
.npmrc
