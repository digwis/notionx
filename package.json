{
  "name": "vinext-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "dev:moviebluebook": "pnpm --filter @nextion/moviebluebook dev",
    "nextion:doctor": "pnpm --filter @nextion/core doctor",
    "tools:build": "pnpm --filter create-nextion-app build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "eslint-import-resolver-typescript": "^4",
    "eslint-plugin-import": "^2",
    "globals": "^15",
    "husky": "^9",
    "typescript": "^5",
    "typescript-eslint": "^8"
  },
  "pnpm": {
    "patchedDependencies": {
      "vinext@0.1.1": "patches/vinext@0.1.1.patch"
    }
  }
}
