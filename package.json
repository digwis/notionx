    "dev:vinext": "pnpm --filter @vinext/starter dev:vinext",
    "foundation:doctor": "pnpm --filter @vinext/foundation foundation:doctor",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "eslint-import-resolver-typescript": "^4",
    "eslint-plugin-import": "^2",
    "globals": "^15",
    "husky": "^9",
    "typescript": "^5",
    "typescript-eslint": "^8"
  }
}
