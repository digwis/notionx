{
  "name": "vinext-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "scaffold-test:check": "node scripts/check-scaffold-test.mjs",
    "scaffold-test:dev": "node scripts/scaffold-test-dev.mjs",
    "scaffold-test:notion:check": "node scripts/scaffold-test-notion-check.mjs",
    "scaffold-test:sync": "node scripts/sync-scaffold-test.mjs",
    "test-app:check": "pnpm scaffold-test:check",
    "test-app:dev": "pnpm scaffold-test:dev",
    "test-app:notion:check": "pnpm scaffold-test:notion:check",
    "test-app:sync": "pnpm scaffold-test:sync",
    "dev:core": "pnpm --filter @notionx/core dev",
    "build:core": "pnpm --filter @notionx/core build",
    "dev:all": "pnpm --filter @notionx/core dev",
    "notionx:doctor": "pnpm --filter @notionx/core doctor",
    "tools:build": "pnpm --filter @notionx/cli build",
    "release:check": "pnpm -r typecheck && pnpm -r lint && pnpm changeset status --help",
    "release:check:core": "pnpm --filter @notionx/core typecheck && pnpm --filter @notionx/core lint",
    "release:check:cli": "pnpm --filter @notionx/cli test",
    "release:check:skill": "pnpm --filter @notionx/skill typecheck && pnpm --filter @notionx/skill lint",
    "release:status": "node scripts/check-changeset.mjs",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@eslint/js": "^9",
    "eslint-import-resolver-typescript": "^4",
    "eslint-plugin-import": "^2",
    "globals": "^15",
    "husky": "^9",
    "typescript": "^5",
    "typescript-eslint": "^8"
  }
}
