# Local Cloudflare bindings. Real values are written into `.dev.vars`
# by `pnpm create nextion-app` (or `pnpm exec vinext deploy` in repair
# mode). `.dev.vars` is git-ignored — DO NOT commit it.
#
# To override any value without re-running the scaffolder, edit
# `.dev.vars` directly. The keys below are the ones the runner expects
# to find; if a key is missing the loader falls back to the empty
# string and the relevant feature (Turnstile, Resend, Google login,
# Notion-backed content, etc.) is disabled.

# --- D1 / KV bindings (auto-filled by scaffolder) ---
D1_DATABASE_ID=
KV_NAMESPACE_ID=

# --- Cloudflare Turnstile (optional) ---
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Notion (optional; required for Notion-backed content) ---
NOTION_TOKEN=
NOTION_DATA_SOURCE_ID=
NOTION_PAGES_DATA_SOURCE_ID=
NOTION_SITE_SETTINGS_DATA_SOURCE_ID=

# --- Resend (optional; required for transactional email) ---
RESEND_API_KEY=
RESEND_FROM=

# --- Google OAuth (optional; required for "Login with Google") ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
