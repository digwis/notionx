const fallbackBlocks = (text: string): NotionBlock[] => [
  {
    id: "fallback-intro",
    type: "paragraph",
    paragraph: {
      rich_text: [
        {
          type: "text",
          text: { content: text },
          plain_text: text,
        },
      ],
    },
  },
];

type BlockPropertyValue = string | string[] | number | boolean;

type BlockCta = {
  label: string;
  href: string;
};

type FeatureGridItem = {
  title: string;
  description: string;
  icon: string;
  href?: string;
};

export type StructuredHeroBlock = {
  type: "hero";
  slug: string;
  title: string;
  description: string;
  eyebrow: string;
  headline: string;
  subheadline: string;
  primaryCta: BlockCta | null;
  secondaryCta: BlockCta | null;
  alignment: "left" | "center";
  theme: "default" | "muted" | "inverse";
  coverImage: string | null;
  editUrl: string | null;
};

export type StructuredFeatureGridBlock = {
  type: "feature-grid";
  slug: string;
  title: string;
  description: string;
  headline: string;
  body: string;
  columns: 2 | 3 | 4;
  items: FeatureGridItem[];
  coverImage: string | null;
  editUrl: string | null;
};

export type StructuredStoryBlock = {
  type: "story";
  slug: string;
  title: string;
  description: string;
  headline: string;
  body: string;
  quote: string;
  quoteAttribution: string;
  mediaUrl: string | null;
  layout: "text-left" | "media-left" | "media-right";
  coverImage: string | null;
  editUrl: string | null;
};

export type StructuredLatestPostsBlock = {
  type: "latest-posts";
  slug: string;
  title: string;
  description: string;
  headline: string;
  body: string;
  count: number;
  primaryCta: BlockCta | null;
  coverImage: string | null;
  editUrl: string | null;
};

export type LegacyStructuredPageBlock = {
  type: "legacy";
  slug: string;
  title: string;
  description: string;
  variant: string;
  coverImage: string | null;
  editUrl: string | null;
  blocks: NotionBlock[];
};

export type StructuredPageBlock =
  | StructuredHeroBlock
  | StructuredFeatureGridBlock
  | StructuredStoryBlock
  | StructuredLatestPostsBlock
  | LegacyStructuredPageBlock;

export type SitePage = Omit<BaseSitePage, "structuredBlocks"> & {
  structuredBlocks: StructuredPageBlock[];
};

