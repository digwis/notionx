export default async function LoginPage({
  searchParams,
}: {
  searchParams?: Promise<{ error?: string }>;
}) {
  const sp = (await searchParams) ?? {};
  return (
    <main
      style={{
        fontFamily: "system-ui, sans-serif",
        minHeight: "100vh",
        display: "flex",
        alignItems: "center",
        justifyContent: "center",
        background: "#fafafa",
      }}
    >
      <form
        action={emailLoginAction}
        style={{
          background: "#fff",
          padding: "2rem",
          border: "1px solid #ddd",
          borderRadius: 8,
          width: 320,
          display: "flex",
          flexDirection: "column",
          gap: "0.75rem",
        }}
      >
        <h1 style={{ fontSize: "1.5rem", margin: 0 }}>Sign in</h1>
        {sp.error ? (
          <p style={{ color: "#b00", fontSize: "0.875rem" }}>
            {sp.error}
          </p>
        ) : null}
        <label htmlFor="email" style={{ fontSize: "0.875rem" }}>
          Email
        </label>
        <input
          id="email"
          name="email"
          type="email"
          required
          autoFocus
          style={{ padding: "0.5rem", border: "1px solid #ccc", borderRadius: 4 }}
        />
        <label htmlFor="password" style={{ fontSize: "0.875rem" }}>
          Password
        </label>
        <input
          id="password"
          name="password"
          type="password"
          required
          style={{ padding: "0.5rem", border: "1px solid #ccc", borderRadius: 4 }}
        />
        <button
          type="submit"
          style={{
            padding: "0.5rem 1rem",
            background: "#111",
            color: "#fff",
            border: 0,
            borderRadius: 4,
            cursor: "pointer",
          }}
        >
          Sign in
        </button>
        <p style={{ fontSize: "0.75rem", color: "#666", margin: 0 }}>
          Cookie: {authConfig.sessionCookie.name}
        </p>
      </form>
    </main>
  );
}
