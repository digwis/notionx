// Public list page for the first content source (default: blog).
// The list itself is a content-source route, while its page title,
// SEO copy, nav placement, and shell visibility can be edited through
// the Notion-backed Pages model.

import type { Metadata } from "next";
import { listGenericNotionContent } from "@notionx/core/notion";
import { PostCard } from "@/components/content/post-card";
import { {{contentSourceVarName}} } from "@/lib/content/models";
import { SiteShell } from "@/components/site/site-shell";
import { getSitePageForContentSource } from "@/lib/pages/source";

export const revalidate = 300;

export async function generateMetadata(): Promise<Metadata> {
  const page = await getSitePageForContentSource("{{contentSourceId}}");
  return {
    title: page?.seoTitle || page?.title || "{{contentSourceListTitle}}",
    description:
      page?.seoDescription || page?.description || "{{contentSourceListDescription}}",
  };
}

export default async function {{contentSourceConstName}}Page() {
  const items = await listGenericNotionContent({{contentSourceVarName}});
  const page = await getSitePageForContentSource("{{contentSourceId}}");
  const title = page?.title || "{{contentSourceListTitle}}";
  const description = page?.description || "{{contentSourceListDescription}}";

  if (items.length === 0) {
    return (
      <SiteShell
        showHeader={page?.showHeader ?? true}
        showFooter={page?.showFooter ?? true}
      >
        <main className="container mx-auto max-w-4xl px-4 py-16">
          <h1 className="text-4xl font-bold tracking-tight">{title}</h1>
          <p className="mt-4 text-muted-foreground">{description}</p>
          <div className="mt-12 rounded-lg border border-dashed bg-muted/30 px-6 py-16 text-center">
            <p className="text-sm text-muted-foreground">
              {{contentSourceEmptyState}}
            </p>
            <p className="mt-2 text-xs text-muted-foreground">
              在 Notion 中把 <code>{{contentSourceTitle}}</code> 行的{" "}
              <code>Published</code> 勾选后，会自动出现在这里。
            </p>
          </div>
        </main>
      </SiteShell>
    );
  }

  return (
    <SiteShell
      showHeader={page?.showHeader ?? true}
      showFooter={page?.showFooter ?? true}
    >
      <main className="container mx-auto max-w-4xl px-4 py-16">
        <header className="mb-12 space-y-3">
          <h1 className="text-4xl font-bold tracking-tight">{title}</h1>
          <p className="text-muted-foreground">{description}</p>
        </header>

        <ul className="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {items.map((item) => (
            <li key={item.pageId}>
              <PostCard item={item} href={`{{contentSourceListPath}}/${item.slug}`} />
            </li>
          ))}
        </ul>
      </main>
    </SiteShell>
  );
}
